<script>
function searchCommands() {
    let input = document.getElementById("search").value.toLowerCase();
    let commands = document.getElementsByClassName("command");

    for (let i = 0; i < commands.length; i++) {
        let text = commands[i].innerText.toLowerCase();
        commands[i].style.display = text.includes(input) ? "block" : "none";
    }
}

function filterCommands(category) {
    let commands = document.getElementsByClassName("command");

    for (let i = 0; i < commands.length; i++) {
        if (category === "all") {
            commands[i].style.display = "block";
        } else {
            commands[i].style.display =
                commands[i].classList.contains(category) ? "block" : "none";
        }
    }
}
</script>
