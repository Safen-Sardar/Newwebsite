<!-- COMMANDS SECTION -->
<section class="commands">

<h2>Bot Commands</h2>

<!-- SEARCH -->
<input type="text" id="search" placeholder="Search commands..." onkeyup="searchCommands()">

<!-- FILTER -->
<div class="filters">
<button onclick="filterCommands('all')">All</button>
<button onclick="filterCommands('security')">Security</button>
<button onclick="filterCommands('admin')">Admin</button>
<button onclick="filterCommands('fun')">Fun</button>
</div>

<!-- COMMAND LIST -->
<div class="command-list" id="commandList">

<!-- SECURITY -->
<div class="command security">!ban - Ban user</div>
<div class="command security">!kick - Kick user</div>
<div class="command security">!mute - Mute user</div>
<div class="command security">!unmute - Unmute user</div>
<div class="command security">!lock - Lock channel</div>
<div class="command security">!unlock - Unlock channel</div>
<div class="command security">!anti-raid - Enable anti raid</div>
<div class="command security">!anti-link - Block links</div>
<div class="command security">!warn - Warn user</div>
<div class="command security">!clearwarns - Clear warns</div>

<!-- ADMIN -->
<div class="command admin">!setup - Setup bot</div>
<div class="command admin">!prefix - Change prefix</div>
<div class="command admin">!role - Add role</div>
<div class="command admin">!removerole - Remove role</div>
<div class="command admin">!nickname - Change nickname</div>
<div class="command admin">!slowmode - Set slowmode</div>
<div class="command admin">!announce - Make announcement</div>
<div class="command admin">!embed - Create embed</div>
<div class="command admin">!backup - Backup server</div>
<div class="command admin">!restore - Restore backup</div>

<!-- FUN -->
<div class="command fun">!meme - Random meme</div>
<div class="command fun">!joke - Tell joke</div>
<div class="command fun">!8ball - Ask question</div>
<div class="command fun">!coinflip - Flip coin</div>
<div class="command fun">!avatar - Show avatar</div>
<div class="command fun">!gif - Random gif</div>
<div class="command fun">!quote - Random quote</div>
<div class="command fun">!roll - Roll dice</div>
<div class="command fun">!ship - Ship users</div>
<div class="command fun">!hack - Fake hack</div>

<!-- EXTRA (40 total) -->
<div class="command admin">!help - Show help</div>
<div class="command security">!logs - Show logs</div>
<div class="command admin">!settings - Bot settings</div>
<div class="command fun">!ping - Bot ping</div>
<div class="command security">!blacklist - Blacklist user</div>
<div class="command security">!whitelist - Whitelist user</div>
<div class="command admin">!autorole - Set auto role</div>
<div class="command admin">!welcome - Welcome system</div>
<div class="command fun">!rank - User rank</div>
<div class="command fun">!level - User level</div>

</div>
</section>
